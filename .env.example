# =========================================================================
#  Frederiks Bedrijfskleding — omgevingsvariabelen
#  Kopieer naar .env.local (lokaal) en zet dezelfde waarden in
#  Vercel -> Project -> Settings -> Environment Variables.
#  Commit NOOIT .env.local of echte sleutels naar git.
# =========================================================================

# Basis-URL van de site (canonical, sitemap, e-mails)
NEXT_PUBLIC_SITE_URL=https://www.frederiksbedrijfskleding.nl

# --- E-mail (Resend) — voor het advies-/offerteformulier ---
# Zonder key werkt het formulier gewoon; er wordt dan geen mail verstuurd
# (handig voor lokaal/preview). Verifieer het domein in Resend voor livegang.
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL="Frederiks Bedrijfskleding <offerte@frederiksbedrijfskleding.nl>"
LEAD_NOTIFY_EMAIL=info@frederiksbedrijfskleding.nl

# --- Analytics (GA4) — optioneel, koppel aan cookie-consent vóór livegang ---
NEXT_PUBLIC_GA_ID=
